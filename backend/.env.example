MONGO_URI=
JWT_SECRET=
# n8n webhook the backend POSTs to when resumes are uploaded or jobs applied to.
# The workflow Switch node routes by the "event" field: "resume_uploaded" | "job_applied".
N8N_WEBHOOK_URL=http://localhost:5678/webhook/resume-uploaded
# Shared secret sent as the X-N8N-SECRET header on outbound triggers and required
# on the inbound /ai/n8n/callback and /internal/* endpoints. Leave blank to disable
# auth in dev (NOT recommended in production).
N8N_SHARED_SECRET=
FRONTEND_ORIGIN=http://localhost:3000
OPENAI_API_KEY=

# Backblaze B2 (S3-compatible)
B2_ENDPOINT=https://s3.<region>.backblazeb2.com
B2_BUCKET_NAME=
B2_ACCESS_KEY_ID=
B2_SECRET_ACCESS_KEY=
B2_REGION=<region>

# Optional: prefix for organising uploads
B2_UPLOAD_PREFIX=resumes/
